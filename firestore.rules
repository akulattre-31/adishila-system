rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // For this prototype with mock login, allow read/write to all authenticated-like paths.
    // Note: Since Firebase Auth is not used, setting this to true for all. 
    // In production with Firebase Auth: `allow read, write: if request.auth != null;`
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
